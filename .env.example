# Required for authenticated smoke.
BASE_URL=https://riffables.speedrunlabs.ai
SMOKE_EMAIL=qa-admin@example.com
SMOKE_PASSWORD=replace-me

# Optional but recommended when the app routes differ.
LOGIN_PATH=/sign-in
PROTECTED_PATH=/sources
CONSOLE_PATH=/

# Optional: use a previously captured authenticated state instead of logging in through Google each run.
AUTH_STORAGE_STATE=

# Optional public-site smoke.
PUBLIC_SITE_URL=https://tenant.example.com
PUBLIC_EXPECTED_TEXT=

# Optional tenant/workspace assertion after login.
TENANT_EXPECTED_TEXT=

# Optional source connection smoke. Leave empty to skip strict source picker checks.
SOURCE_EXPECTED_CHOICES=YouTube,Spotify,Blog

# Optional YouTube source automation.
SOURCE_YOUTUBE_URL=https://www.youtube.com/@nhnbaohan
SOURCE_YOUTUBE_HANDLE=@nhnbaohan
SOURCE_CONNECT_FULL=false
SOURCE_ACTION_NO_DATA=false
SOURCE_BACKFILL_EMPTY_DATE=2026-07-17
SOURCE_CRAWL_DATA=false
SOURCE_CRAWL_MUTATION=false
SOURCE_EXPECTED_VIDEO_COUNT=2
SOURCE_CRAWL_AUDIO_TITLE=test 2
SOURCE_CRAWL_SILENT_TITLE=test 1
SOURCE_CRAWL_AUDIO_EXPECTED_STATE=Failed
SOURCE_CRAWL_SILENT_EXPECTED_STATE=No insights
SOURCE_CRAWL_SEARCH_KEYWORD=test 2
SOURCE_CRAWL_WAIT_MS=120000
SOURCE_GOOGLE_EMAIL=
SOURCE_GOOGLE_PASSWORD=

# Optional auth account flows.
SIGNUP_NAME=QA Creator
SIGNUP_EMAIL=qa-new-creator@example.com
SIGNUP_PASSWORD=replace-me
RESET_EMAIL=qa-admin@example.com
CHANGE_PASSWORD_EMAIL=qa-admin@example.com
CHANGE_PASSWORD_CURRENT_PASSWORD=replace-me

# Optional setup-organization flows.
SETUP_EXISTING_EMAIL=qa-admin@example.com
SETUP_EXISTING_PASSWORD=replace-me
SETUP_SIGNUP_EMAIL_PREFIX=qa-org-auto+
SETUP_SIGNUP_EMAIL_DOMAIN=example.com
SETUP_SIGNUP_PASSWORD=replace-me

# Optional Home/onboarding flows. Falls back to SETUP_SIGNUP_* when empty.
HOME_SIGNUP_EMAIL_PREFIX=
HOME_SIGNUP_EMAIL_DOMAIN=
HOME_SIGNUP_PASSWORD=

# Optional workspace/account menu flows. Falls back to SMOKE_* when empty.
WORKSPACE_EXISTING_EMAIL=
WORKSPACE_EXISTING_PASSWORD=

# Optional selector overrides. Use these when labels/placeholders differ.
SELECTOR_EMAIL=
SELECTOR_PASSWORD=
SELECTOR_SUBMIT=
SELECTOR_SIGN_OUT=
